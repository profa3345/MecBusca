{
  "name": "mecbusca-functions",
  "description": "MecBusca Cloud Functions v2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "serve":  "firebase emulators:start --only functions,firestore,auth",
    "deploy": "firebase deploy --only functions",
    "logs":   "firebase functions:log",
    "lint":   "eslint .",
    "test":   "jest --forceExit"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin":     "^12.1.0",
    "firebase-functions": "^5.1.0"
  },
  "devDependencies": {
    "firebase-tools": "^13.10.0",
    "eslint":         "^8.57.0",
    "jest":           "^29.7.0"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 2022
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"]
  }
}
